# secwatch Discord alerting — OPTIONAL webhook secret template.
#
# secwatch can post high-severity alerts to a Discord channel via an incoming
# webhook. Keeping the URL in a file (instead of secwatch.yaml) keeps the secret
# out of your config and out of version control.
#
# Setup:
#   1. In Discord, on the channel you want alerts in:
#        Edit Channel -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
#   2. Copy this file to a private location and paste the URL below (no quotes):
#        cp discord-webhook.env.example .secrets/discord-webhook.env
#        chmod 600 .secrets/discord-webhook.env
#   3. Point secwatch at it in secwatch.yaml:
#        alerting:
#          discord_webhook_file: /path/to/.secrets/discord-webhook.env
#          discord_webhook_file_key: SECWATCH_DISCORD_WEBHOOK_URL
#      (secwatch also looks in ./.secrets/discord-webhook.env by default, so if
#       you use that path you can skip the discord_webhook_file line entirely.)
#
# Alternatives: set the URL inline as alerting.discord_webhook_url in
# secwatch.yaml, or via the SECWATCH_DISCORD_WEBHOOK_URL environment variable.
#
# NOTE: .secrets/ is gitignored — never commit the real file. Only THIS
# .example template belongs in the repo.

SECWATCH_DISCORD_WEBHOOK_URL=
