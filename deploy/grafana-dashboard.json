{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping secwatch /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "secwatch",
  "uid": "secwatch",
  "tags": ["secwatch", "security"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(secwatch_build_info, node)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active bans",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(secwatch_bans_active{node=~\"$node\"})", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "High-severity events (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [{ "expr": "sum(secwatch_high_events_24h{node=~\"$node\"})", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "KEV (actively-exploited) CVEs",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [{ "expr": "sum(secwatch_vulnerabilities{kev=\"true\",node=~\"$node\"})", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Log-source lag (max, s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "max(secwatch_last_event_age_seconds{node=~\"$node\"})", "refId": "A" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Events (24h) by severity",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum by (severity) (secwatch_events_recent{node=~\"$node\"})", "legendFormat": "{{severity}}", "refId": "A" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Active bans by source",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "sum by (source) (secwatch_bans_by_source{node=~\"$node\"})", "legendFormat": "{{source}}", "refId": "A" }]
    },
    {
      "id": 7, "type": "table", "title": "Nodes / versions",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "targets": [{ "expr": "secwatch_build_info{node=~\"$node\"}", "format": "table", "instant": true, "refId": "A" }]
    }
  ]
}
